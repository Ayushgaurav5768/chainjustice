# Frontend + API runtime (Next.js app in chainjustice1/app)

# REQUIRED FOR WALLET + RPC UX (safe defaults provided if omitted)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CHAINJUSTICE_PROGRAM_ID=G6UN14ZNB6TpXgohEzmaXBGmfwzpmgRPi4w7p4p39woC
NEXT_PUBLIC_GATEWAY_URL=https://gateway.pinata.cloud

# Optional alias for program id; only used if NEXT_PUBLIC_CHAINJUSTICE_PROGRAM_ID is missing.
NEXT_PUBLIC_PROGRAM_ID=

# OPTIONAL: live AI analysis (without these, API returns structured advisory mock/fallback output)
GOOGLE_API_KEY=
# Optional alias accepted by app config:
GEMINI_API_KEY=

# OPTIONAL: Pinata upload (without these, /api/ipfs returns mock CID + gateway URL)
PINATA_JWT=
# Optional legacy auth pair (used when PINATA_JWT is missing):
PINATA_API_KEY=
PINATA_SECRET=

# OPTIONAL: AI council provider pool used by conflict firewall routing in /api/ai-legal
AI_COUNCIL_PROVIDER_POOL=gemini,openai,anthropic
