# Workspace-level deployment reference for chainjustice1
# Copy frontend vars into chainjustice1/app/.env.local for local development,
# and into your frontend host (Vercel) environment settings for production.

# ---------- Frontend / API (Next.js in app/) ----------
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CHAINJUSTICE_PROGRAM_ID=G6UN14ZNB6TpXgohEzmaXBGmfwzpmgRPi4w7p4p39woC
NEXT_PUBLIC_GATEWAY_URL=https://gateway.pinata.cloud
GOOGLE_API_KEY=
GEMINI_API_KEY=
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET=
AI_COUNCIL_PROVIDER_POOL=gemini,openai,anthropic

# ---------- Anchor / Solana CLI ----------
# Usually configured via Anchor.toml and Solana CLI config.
# Keep these as optional helpers for CI or scripted environments.
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
ANCHOR_WALLET=./target/deploy/chainjustice-keypair.json
SOLANA_URL=https://api.devnet.solana.com
SOLANA_WALLET=./target/deploy/chainjustice-keypair.json
